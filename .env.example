# ─────────────────────────────────────────────────────────────────────────────
# Finance Dashboard — variáveis de ambiente
# Copie para `.env` e preencha. NUNCA commitar o .env real.
# ─────────────────────────────────────────────────────────────────────────────

# Porta do backend Fastify (só localhost). O front (Vite) usa 5273 e faz proxy /api.
PORT=5275

# Chave de criptografia at-rest dos refresh tokens OAuth (AES-256-GCM).
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 32 bytes em base64. Se ausente, o app cai para DPAPI no Windows (ver docs/setup-google.md).
FINANCE_ENCRYPTION_KEY=

# ── Google Cloud / YouTube Analytics (Epic 0 · S0.3) ────────────────────────
# Crie um OAuth Client tipo "Desktop app" (loopback) no Google Cloud Console.
# Publique a consent screen em PRODUCTION para o refresh token não expirar em 7 dias (R1).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Porta do redirect loopback usado no fluxo `npm run auth`.
GOOGLE_OAUTH_REDIRECT_PORT=5277

# ── Hotmart (Epic 0 · S0.4) ─────────────────────────────────────────────────
# Credenciais NOVAS de desenvolvedor (NÃO reaproveitar a antiga hardcoded no n8n — R5).
# Painel Hotmart → Ferramentas → Credenciais Hotmart / API.
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
# Basic = base64("client_id:client_secret"). O app calcula sozinho se você deixar vazio.
HOTMART_BASIC=
# Ambiente Hotmart: "production" (padrão) ou "sandbox".
HOTMART_ENV=production
# Qual papel de comissão é o SEU quando a venda tem vários envolvidos
# (PRODUCER | AFFILIATE | CO_PRODUCER). A comissão gravada é a líquida desse papel.
HOTMART_ROLE=PRODUCER
